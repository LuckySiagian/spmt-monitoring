# ============================================
# SPMT MONITORING - ENVIRONMENT CONFIGURATION
# ============================================
# SECURITY: Copy this to .env and update values
# NEVER commit .env to version control
# ============================================

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=generate_strong_password_here
DB_NAME=spmt_monitoring
# ✅ SECURITY: Set to 'require' in production for encrypted connections
DB_SSLMODE=require

# 🔐 PRODUCTION: Generate strong JWT secret:
#    Linux/Mac: openssl rand -base64 32
#    PowerShell: [Convert]::ToBase64String((1..32|%{[byte]Random}))
JWT_SECRET=generate_with_openssl_rand_-base64_32_command

# JWT token expiration time in hours (set to 2 in production for security)
JWT_EXPIRY_HOURS=2

SERVER_PORT=8080
# ✅ SECURITY: Update to your domain in production
FRONTEND_URL=http://localhost:5173
